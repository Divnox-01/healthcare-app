generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  adminProfile   AdminProfile?
  symptomHistory SymptomHistory[]
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model PatientProfile {
  id            String             @id @default(uuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id])
  firstName     String
  lastName      String
  age           Int? // NEW
  healthScore   Int? // NEW
  appointments  Appointment[]
  records       MedicalRecord[]
  medicines     MedicineReminder[]
  queries       PatientQuery[] // NEW
  prescriptions Prescription[] // NEW
}

model DoctorProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  specialization String
  location       String
  rating         Float          @default(0)
  experience     Int            @default(0) // NEW
  fees           Float          @default(0) // NEW
  description    String? // NEW
  imageUrl       String? // NEW
  responseRate   String? // NEW
  appointments   Appointment[]
  queries        PatientQuery[] // NEW
  prescriptions  Prescription[] // NEW
}

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  name   String
}

model Appointment {
  id            String         @id @default(uuid())
  date          DateTime
  timeSlot      String
  status        ApptStatus     @default(BOOKED)
  queueNum      Int? // Tracking queue placement
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        DoctorProfile  @relation(fields: [doctorId], references: [id])
  meetingLink   String? // Telehealth Link
  paymentStatus String         @default("PENDING") // NEW
  paymentId     String? // NEW
  prescription  Prescription? // NEW
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([doctorId, date, timeSlot])
}

enum ApptStatus {
  BOOKED
  WAITING
  IN_CONSULTATION
  COMPLETED
  CANCELLED
}

model MedicalRecord {
  id            String         @id @default(uuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  documentUrl   String
  extractedText String? // NEW: OCR Extracted Text
  notes         String?
  createdAt     DateTime       @default(now())
}

model MedicineReminder {
  id           String         @id @default(uuid())
  patientId    String
  patient      PatientProfile @relation(fields: [patientId], references: [id])
  medicineName String
  dosage       String
  time         String // e.g. "08:00 AM"
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
}

model Prescription {
  id            String         @id @default(uuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        DoctorProfile  @relation(fields: [doctorId], references: [id])
  appointmentId String?        @unique
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  medicines     String // JSON string or list of meds
  notes         String?
  createdAt     DateTime       @default(now())
}

model PatientQuery {
  id        String         @id @default(uuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    DoctorProfile  @relation(fields: [doctorId], references: [id])
  query     String
  response  String?
  status    QueryStatus    @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum QueryStatus {
  OPEN
  ANSWERED
  CLOSED
}

model SymptomHistory {
  id                      String   @id @default(uuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id])
  symptoms                String
  predictedSpecialization String
  riskLevel               String
  confidenceScore         Int
  createdAt               DateTime @default(now())
}
